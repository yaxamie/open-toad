# SQLite — local dev default (no setup required)
DATABASE_URL=sqlite://./opentoad.db

# Postgres — Docker / production (comment out the SQLite line above and use this)
# DATABASE_URL=postgres://opentoad:yourpassword@localhost:5432/opentoad
# POSTGRES_PASSWORD=yourpassword   # used by docker-compose to create the db

PORT=3131
POND_DOMAIN=your.pond

# Generate with: npm run keygen
POND_PRIVATE_KEY=
POND_PUBLIC_KEY=
